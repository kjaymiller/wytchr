API_TOKEN=changeme
YTDL_SUB_API_URL=http://ytdl-sub-api:5000
YTDL_SUB_API_TOKEN=changeme
TZ=America/New_York
POLL_INTERVAL_MINUTES=30
POLL_LIMIT=30
# Optional: YouTube Data API v3 key. When set, wytchr fetches each
# new video's description and includes it in the `notes` field of
# outbound webhooks. Without it, description/notes stay null.
# Get one at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
